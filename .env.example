# Sales OS — environment

# --- Database (system of record) --------------------------------------------
# Standalone CRM: Sales OS owns its data. Local dev uses a SQLite file (zero
# setup). Deploy points at Turso (libSQL): DATABASE_URL=libsql://… + token.
DATABASE_URL=file:.data/salesos.db
# DATABASE_AUTH_TOKEN=         # for Turso (remote libSQL)
# WORKSPACE_ID=ws_default

# --- LLM provider -----------------------------------------------------------
# stub     : deterministic, no server — runs/demos with zero infrastructure.
# llamacpp : local llama.cpp OpenAI-compatible endpoint (llama-swap hot-swap).
# openai   : any hosted OpenAI-compatible endpoint (OpenAI, Groq, Together…) —
#            use this for cloud deploy (llama.cpp is local-only).
LLM_PROVIDER=stub

LLAMACPP_BASE_URL=http://localhost:8080/v1
# LLAMACPP_API_KEY=
# LLM_TIMEOUT_MS=60000

# Hosted provider (when LLM_PROVIDER=openai). Point at OpenAI, or a hosted OPEN
# model on Groq/Together to keep cost low + the open-model ethos.
# OPENAI_BASE_URL=https://api.openai.com/v1   # or https://api.groq.com/openai/v1
# OPENAI_API_KEY=
# Set MODEL_* (below) to the hosted provider's model ids when using openai.

# --- Per-agent models (hot-swap keys) ---------------------------------------
# These must match the model names defined in your llama-swap config
# (see infra/llama-swap.yaml). Override to downshift to whatever your hardware
# can run. See src/lib/llm/models.ts for which agent uses which tier.
MODEL_FAST=qwen2.5-3b-instruct
MODEL_WORKER=qwen2.5-7b-instruct    # Scout, Forecaster
MODEL_MID=qwen2.5-14b-instruct      # Auditor (flag accuracy matters)
MODEL_BRAIN=qwen2.5-32b-instruct    # Sparring Partner (role-play — the brain)

# --- Data source ------------------------------------------------------------
# db        : our own database — the system of record (default).
# synthetic : the sanitized Ayala Land pack (offline demo, no DB).
# hubspot   : live HubSpot CRM as a connector (DATA_SOURCE=hubspot + token).
DATA_SOURCE=db

# HubSpot Private App token (only when DATA_SOURCE=hubspot). Read scopes:
#   crm.objects.contacts.read, crm.objects.companies.read,
#   crm.objects.deals.read, crm.objects.owners.read,
#   sales-email-read (+ calls/meetings/notes read for full activity).
# For agent WRITES (Dispatcher routing leads): crm.objects.contacts.write.
# HUBSPOT_ACCESS_TOKEN=
# DATA_TTL_MS=60000          # how long a fetched snapshot is cached (ms)

# --- Agent autonomy ---------------------------------------------------------
# Per-agent: "ask" (propose → one-tap approve, default) or "auto" (act without
# asking). External sends (send-email) are always "ask" regardless. Internal,
# reversible writes like lead routing are safe to set "auto".
# AUTONOMY_DISPATCHER=ask

# --- Email sending (Scribe) -------------------------------------------------
# Without a provider, Scribe only LOGS the follow-up to the HubSpot timeline.
# Resend (https://resend.com): create an API key. In test mode you can send
# FROM onboarding@resend.dev only TO your own Resend account email.
# RESEND_API_KEY=
# EMAIL_FROM=Sales OS <onboarding@resend.dev>
# SANDBOX (recommended while testing): redirect EVERY send to one address so no
# prospect is ever emailed. Set this to your own inbox.
# EMAIL_OVERRIDE_TO=you@example.com
# Send to the REAL prospect address (production) — only if true AND no override.
# Off by default so a real prospect is never emailed by accident.
# EMAIL_ALLOW_REAL=false

# --- Triggers (agents fire on their own) ------------------------------------
# The in-process scheduler starts on server boot. Set to false to disable it
# (you can still drive POST /api/triggers/tick from an external cron).
# TRIGGERS_AUTORUN=true
# TRIGGER_TICK_MS=60000        # how often the scheduler evaluates triggers
# TRIGGER_LEAD_SCAN_MS=120000  # min gap between Dispatcher lead scans
# TRIGGER_AUDIT_MS / TRIGGER_FORECAST_MS  # nightly agents (default 24h)

# Which seat the workspace shows. Defaults to the first rep in the data.
# SALESOS_REP_ID=

# --- Deploy (Vercel + Turso) ------------------------------------------------
# On serverless the in-process scheduler can't run — set TRIGGERS_AUTORUN=false
# and let Vercel Cron hit /api/triggers/tick (configured in vercel.json).
# CRON_SECRET=                 # Vercel sends it as Bearer; tick GET verifies it.
# APP_PASSWORD=                # if set, HTTP Basic-auth gate on the demo.
